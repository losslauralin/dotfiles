# whkd configuration for Komorebi
# Ref: https://github.com/LGUG2Z/komorebi/blob/master/docs/whkdrc.sample

.shell cmd

# Reload
alt + o                 : taskkill /f /im whkd.exe && start /b whkd
alt + shift + o         : komorebic reload-configuration

# Close & Minimize
alt + q                 : komorebic close
alt + m                 : komorebic minimize

# Focus windows
alt + h                 : komorebic focus left
alt + j                 : komorebic focus down
alt + k                 : komorebic focus up
alt + l                 : komorebic focus right
alt + shift + oem_4     : komorebic cycle-focus previous # oem_4 is [
alt + shift + oem_6     : komorebic cycle-focus next # oem_6 is ]

# Move windows
alt + shift + h         : komorebic move left
alt + shift + j         : komorebic move down
alt + shift + k         : komorebic move up
alt + shift + l         : komorebic move right
alt + shift + return    : komorebic promote

# Stack windows
alt + left              : komorebic stack left
alt + down              : komorebic stack down
alt + up                : komorebic stack up
alt + right             : komorebic stack right
alt + oem_1             : komorebic unstack # oem_1 is ;
# alt + [ / ] reassigned to scrolling-layout-columns (see Scrolling section)
# To cycle through stacked windows use alt + shift + [ / ] (already cycle-focus)

# Resize
alt + oem_plus          : komorebic resize-axis horizontal increase
alt + oem_minus         : komorebic resize-axis horizontal decrease
alt + shift + oem_plus  : komorebic resize-axis vertical increase
alt + shift + oem_minus : komorebic resize-axis vertical decrease

# Manipulate windows
alt + t                 : komorebic toggle-float
alt + shift + f         : komorebic toggle-monocle
alt + f                 : komorebic toggle-maximize
alt + v                 : komorebic toggle-split

# Layouts
alt + c                 : komorebic cycle-layout next
alt + shift + c         : komorebic cycle-layout previous
alt + x                 : komorebic flip-layout horizontal
alt + y                 : komorebic flip-layout vertical

# Window manager options
alt + shift + r         : komorebic retile
alt + p                 : komorebic toggle-pause
alt + i                 : komorebic toggle-shortcuts

# Launch terminal
alt + return            : wt.exe

# Focus recent workspace
alt + d                 : komorebic focus-last-workspace

# Focus workspaces (Monitor 0: 1-5, Monitor 1: 6-0)
alt + 1                 : komorebic focus-monitor-workspace 0 0
alt + 2                 : komorebic focus-monitor-workspace 0 1
alt + 3                 : komorebic focus-monitor-workspace 0 2
alt + 4                 : komorebic focus-monitor-workspace 0 3
alt + 5                 : komorebic focus-monitor-workspace 0 4
alt + 6                 : komorebic focus-monitor-workspace 1 0
alt + 7                 : komorebic focus-monitor-workspace 1 1
alt + 8                 : komorebic focus-monitor-workspace 1 2
alt + 9                 : komorebic focus-monitor-workspace 1 3
alt + 0                 : komorebic focus-monitor-workspace 1 4

# Move windows across workspaces
alt + shift + 1         : komorebic move-to-monitor-workspace 0 0
alt + shift + 2         : komorebic move-to-monitor-workspace 0 1
alt + shift + 3         : komorebic move-to-monitor-workspace 0 2
alt + shift + 4         : komorebic move-to-monitor-workspace 0 3
alt + shift + 5         : komorebic move-to-monitor-workspace 0 4
alt + shift + 6         : komorebic move-to-monitor-workspace 1 0
alt + shift + 7         : komorebic move-to-monitor-workspace 1 1
alt + shift + 8         : komorebic move-to-monitor-workspace 1 2
alt + shift + 9         : komorebic move-to-monitor-workspace 1 3
alt + shift + 0         : komorebic move-to-monitor-workspace 1 4

# Switch between monitors
alt + oem_comma         : komorebic cycle-monitor previous
alt + oem_period        : komorebic cycle-monitor next

# Send window to the other monitor
alt + shift + oem_comma : komorebic cycle-move-to-monitor previous
alt + shift + oem_period: komorebic cycle-move-to-monitor next

# === Scrolling layout control (Niri-style) ===
# Default layout for every workspace is Scrolling (see komorebi.json).
# columns control: alt + [ = 1 column (full width), alt + ] = 3 columns (denser)
alt + oem_4             : komorebic scrolling-layout-columns 1 # alt + [
alt + oem_6             : komorebic scrolling-layout-columns 3 # alt + ]
# Switch the focused workspace's layout in/out of Scrolling
alt + shift + s         : komorebic change-layout scrolling
alt + shift + b         : komorebic change-layout bsp

# === Keybindings help popup (yasb whkd widget) ===
# Click the keyboard icon on the bar to open the popup.
# alt + / = fallback: touch yasb config so watch_config re-renders the bar
alt + slash             : pwsh -NoProfile -Command "(Get-Item $env:USERPROFILE\.config\yasb\config.yaml).LastWriteTime = Get-Date"
